# Example Nginx Configuration for V2VDB Server Mode
# 
# Usage:
# 1. Start v2vdb in server mode:
#    v2vdb --server --port 8080 --api-key my-secret-key
#
# 2. Add this configuration to your nginx config (e.g. /etc/nginx/sites-available/v2vdb)
#    and reload nginx (sudo systemctl reload nginx).

server {
    listen 80;
    server_name db.yourdomain.com; # Replace with your domain or IP

    # Route all traffic under /v2vdb/ to the database engine
    location /v2vdb/ {
        # Pass requests to the local v2vdb instance running on port 8080
        proxy_pass http://127.0.0.1:8080/;
        
        # Pass the original host and IP headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Automatically inject the API key so frontend clients don't need to expose it
        # ALWAYS handle this over HTTPS in production!
        proxy_set_header X-Api-Key "my-secret-key";

        # Add CORS headers if your web app needs to call this directly from a browser
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type' always;

        # Handle OPTIONS preflight requests directly in nginx for speed
        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin' '*' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'Content-Type' always;
            add_header 'Access-Control-Max-Age' 1728000;
            add_header 'Content-Type' 'text/plain; charset=utf-8';
            add_header 'Content-Length' 0;
            return 204;
        }
    }
}
